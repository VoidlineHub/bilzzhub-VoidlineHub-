-- [[ ⚙️ CONFIG ]] --
local genv = getgenv()
local LP = game:GetService("Players").LocalPlayer
local RS = game:GetService("RunService")
local TS = game:GetService("TweenService")

genv.FlySpeed = 250 
genv.IsFlying = false
genv.ResetInterval = 600 -- Default 10 Menit (600 detik)
genv.FlyLoop = nil

local StartRP = 0
local StartTime = tick()
local CurrentEarning = 0

-- [[ 💰 FORMAT RP ]] --
local function formatRP(p2)
    local s = tostring(math.floor(p2))
    return "Rp " .. s:reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
end

-- [[ 🚀 VELOCITY ENGINE (FORCE SPEED) ]] --
local function ToggleSpeedForce(state)
    if genv.FlyLoop then genv.FlyLoop:Disconnect() genv.FlyLoop = nil end

    if state then
        workspace.Gravity = 0
        local lastReset = tick()
        
        genv.FlyLoop = RS.Heartbeat:Connect(function()
            -- Logic Auto Reset
            if tick() - lastReset >= genv.ResetInterval then
                print("🌑 Voidline: Resetting Time...")
                lastReset = tick()
                -- Masukin logic reset motor di sini kalau perlu
            end

            local char = LP.Character
            local seat = char and char:FindFirstChild("Humanoid") and char.Humanoid.SeatPart
            
            if seat and seat.Parent then
                local root = seat
                local velocityVector = root.CFrame.LookVector * (genv.FlySpeed * 0.28)
                
                for _, part in pairs(seat.Parent:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.AssemblyLinearVelocity = velocityVector
                        part.CanCollide = false 
                    end
                end
            end
        end)
    else
        workspace.Gravity = 196.2
        if genv.FlyLoop then genv.FlyLoop:Disconnect() genv.FlyLoop = nil end
    end
end

-- [[ 🎨 UI WINDUI ]] --
local WindUI = loadstring(game:HttpGet('https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua'))()
local Window = WindUI:CreateWindow({
    Title = "VoidlineHub",
    Author = "Bilzz",
    Size = UDim2.fromOffset(450, 420)
})

-- [[ 🏎️ TAB MAIN ]] --
local MainTab = Window:Tab({ Title = "Main", Icon = "zap", Selected = true })

MainTab:Toggle({
    Title = "Force Velocity (Auto Farm)",
    Callback = function(v)
        genv.IsFlying = v
        ToggleSpeedForce(v)
    end
})

MainTab:Slider({
    Title = "Force Speed Control",
    Value = { Min = 0, Max = 100000, Default = 250 },
    Callback = function(v) genv.FlySpeed = v end
})

MainTab:Slider({
    Title = "Reset Interval (Minutes)",
    Desc = "Atur waktu reset (10 - 60 Menit)",
    Value = { Min = 10, Max = 60, Default = 10 },
    Callback = function(v)
        genv.ResetInterval = v * 60 -- Konversi ke detik
    end
})

-- [[ 📊 TAB DASHBOARD ]] --
local StatsTab = Window:Tab({ Title = "Dashboard", Icon = "trending-up" })

local TimeBtn = StatsTab:Button({ Title = "Running Time", Desc = "00:00:00", Icon = "clock" })
local EarningBtn = StatsTab:Button({ Title = "Total Earning", Desc = "Rp 0", Icon = "banknote" })
local MoneyBtn = StatsTab:Button({ Title = "Current Money", Desc = "Rp 0", Icon = "wallet" })
local SysBtn = StatsTab:Button({ Title = "System Status", Desc = "FPS: 0 | Ping: 0ms", Icon = "monitor" })

-- [[ 🔄 REFRESHER LOGIC ]] --
task.spawn(function()
    while true do
        task.wait(1)
        pcall(function()
            local PlayerData = LP:FindFirstChild("PlayerData")
            if PlayerData then
                local CurrentRP = PlayerData.RPValue.Value
                
                if genv.IsFlying then
                    if StartRP == 0 then StartRP = CurrentRP StartTime = tick() end
                    CurrentEarning = CurrentRP - StartRP
                    
                    local diff = tick() - StartTime
                    local h, m, s = math.floor(diff/3600), math.floor((diff%3600)/60), math.floor(diff%60)
                    
                    TimeBtn:SetDesc(string.format("%02d:%02d:%02d", h, m, s))
                    EarningBtn:SetDesc(formatRP(CurrentEarning))
                end
                MoneyBtn:SetDesc(formatRP(CurrentRP))
            end
            
            local fps = math.floor(1 / game:GetService("RunService").RenderStepped:Wait())
            local ping = math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue())
            SysBtn:SetDesc("FPS: " .. fps .. " | Ping: " .. ping .. "ms")
        end)
    end
end)

