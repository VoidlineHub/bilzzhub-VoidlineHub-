-- [[ 🔍 MONEY COOLDOWN CHECKER ]] --
local function IsOnCooldown()
    local cashGui = LP.PlayerGui:FindFirstChild("CashDriving")
    if cashGui and cashGui:FindFirstChild("CashLabel") then
        local txt = cashGui.CashLabel.CashValue.Text:lower()
        return string.find(txt, "cooldown") or string.find(txt, "wait")
    end
    return false
end

-- [[ 🚀 QUADRA TWEEN SYSTEM ]] --
local function VoidlineVehicleTween(targetCFrame, duration)
    local char = LP.Character
    local seat = char and char.Humanoid.SeatPart
    if not seat then return end
    
    local car = seat.Parent
    local primary = car.PrimaryPart or seat
    local oldGravity = workspace.Gravity
    
    workspace.Gravity = 0
    local tweenValue = Instance.new("CFrameValue")
    tweenValue.Value = primary.CFrame
    
    local connection = tweenValue.Changed:Connect(function()
        car:PivotTo(tweenValue.Value)
    end)
    
    local tween = TS:Create(tweenValue, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Value = targetCFrame})
    tween:Play()
    tween.Completed:Wait()
    
    connection:Disconnect()
    tweenValue:Destroy()
    workspace.Gravity = oldGravity
end

-- [[ 🔄 EXECUTION ]] --
local function StartVoidlineFarm()
    while genv.VoidlineAutoFarm do
        local char = LP.Character
        local hum = char:WaitForChild("Humanoid")
        local hrp = char:WaitForChild("HumanoidRootPart")

        -- 1. SPAWN & FORCE TELEPORT KE YAMAHA
        if not hum.SeatPart then
            print("🌑 Voidline: Spawning & Boarding Yamaha...")
            RS.SpawnCarEvents.SpawnCar:FireServer(MOTOR_NAME)
            task.wait(1.2)
            
            -- Cari motor spesifik/motor lu di workspace
            local motor = nil
            for _, v in pairs(workspace:GetChildren()) do
                if (v.Name:find("blog827383") or v.Name:find("Montors")) and v:FindFirstChild("DriveSeat") then
                    motor = v
                    break
                end
            end
            
            if motor then
                local seat = motor.DriveSeat
                -- Langsung TP ke jok tanpa tapi
                hrp.CFrame = seat.CFrame * CFrame.new(0, 1, 0)
                task.wait(0.2)
                fireproximityprompt(seat:FindFirstChildOfClass("ProximityPrompt"))
                task.wait(0.8)
            end
        end

        -- 2. TWEEN BOLAK-BALIK + COOLDOWN AUTO-RESPAWN
        if hum.SeatPart then
            pcall(function()
                -- OTW POS B
                VoidlineVehicleTween(POS_B, 2)
                task.wait(0.5)

                -- Jika Cooldown terdeteksi di UI Money
                if IsOnCooldown() then
                    warn("⚠️ Voidline: Money Limit! Respawning...")
                    hum.Jump = true -- Lompat biar script spawn ulang
                    task.wait(1)
                else
                    -- Balik ke POS A
                    VoidlineVehicleTween(POS_A, 2)
                    task.wait(0.5)
                end
            end)
        end
        task.wait(0.5)
    end
end

