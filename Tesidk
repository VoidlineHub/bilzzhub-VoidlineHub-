    local motor = workspace:FindFirstChild("blog827383Montors_1772824873_8732")
    if motor and motor:FindFirstChild("DriveSeat") then
        local seat = motor.DriveSeat
        hrp.CFrame = seat.CFrame * CFrame.new(0, 2, 2) -- TP Depan Jok
        task.wait(0.3)
        fireproximityprompt(seat:FindFirstChildOfClass("ProximityPrompt"))
    end
    
    task.wait(1)
    
    -- 3. TWEEN BOLAK-BALIK NON-STOP
    while genv.VoidlineAutoFarm do
        pcall(function()
            -- Ke Titik B
            VoidlineVehicleTween(POS_B, 5)
            task.wait(0.5)
            -- Balik Ke Titik A
            VoidlineVehicleTween(POS_A, 5)
            task.wait(0.5)
        end)
        
        -- Berhenti kalau toggle dimatikan
        if not genv.VoidlineAutoFarm then break end
    end
end

